# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# VoidArchive - GITHUB ARCHIVE CALIBRATION (v2.6)
# We keep PROCESSED assets in Git so they can be served.
# We ignore RAW assets because they are too bulky.
/assets/Raw/
/scripts/venv/
/scripts/__pycache__/

# Local ratings store
/.ratings.json
public/assets/Raw/Computer_PresentationPDF.pdf
